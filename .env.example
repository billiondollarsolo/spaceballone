# Required
SPACEBALLONE_MASTER_KEY=your-secret-key-here-min-32-chars

# Domain — set to your FQDN for production (enables automatic Let's Encrypt)
# Leave as "localhost" for local development (Caddy uses self-signed cert)
DOMAIN=localhost

# Database (Docker Compose defaults to PostgreSQL)
# DATABASE_URL=postgres://spaceballone:spaceballone@db:5432/spaceballone?sslmode=disable
# POSTGRES_PASSWORD=spaceballone

# Cloudflare Tunnel (optional — enable with: docker compose --profile tunnel up)
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Optional
# PORT=8080
# FRONTEND_URL=https://localhost
# SESSION_EXPIRY=24h
# HEARTBEAT_INTERVAL=30s

# Manual TLS (only needed for non-Docker deployments — Docker uses Caddy)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
