# Required
SPACEBALLONE_MASTER_KEY=your-secret-key-here-min-32-chars

# Database (uncomment for PostgreSQL)
# DATABASE_URL=postgres://spaceballone:spaceballone@db:5432/spaceballone?sslmode=disable

# Optional
# PORT=8080
# FRONTEND_URL=http://localhost:3000
# SESSION_EXPIRY=24h
# HEARTBEAT_INTERVAL=30s
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem
# POSTGRES_PASSWORD=spaceballone
