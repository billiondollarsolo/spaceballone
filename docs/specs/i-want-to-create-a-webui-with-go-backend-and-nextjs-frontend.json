{
  "name": "SpaceBallOne",
  "slug": "i-want-to-create-a-webui-with-go-backend-and-nextjs-frontend",
  "created": "2026-04-07",
  "status": "ready",
  "overview": "Web-based remote development workspace manager with Go backend and TanStack Start frontend. Manages multiple remote machines via SSH, with persistent terminal sessions, code-server, and Browserless browser preview per project.",
  "tech_stack": {
    "backend": {
      "language": "Go 1.22+",
      "router": "go-chi/chi",
      "orm": "GORM",
      "auth": "Argon2id + server-side sessions",
      "encryption": "AES-256-GCM"
    },
    "frontend": {
      "framework": "TanStack Start (Vite + Vinxi)",
      "routing": "TanStack Router",
      "data_fetching": "TanStack Query",
      "tables": "TanStack Table",
      "forms": "TanStack Form",
      "virtualization": "TanStack Virtual",
      "ui_components": "shadcn (Vite config)",
      "styling": "Tailwind CSS",
      "terminal": "xterm.js"
    },
    "database": {
      "dev": "SQLite",
      "prod": "PostgreSQL"
    },
    "remote_services": {
      "terminal": "tmux",
      "code_editor": "code-server (port 8443)",
      "browser": "Browserless (ports 9222, 5900)",
      "agents": ["OpenCode", "Claude Code", "Codex"]
    },
    "deployment": "Docker Compose (separate containers)"
  },
  "architecture": {
    "ssh_lifecycle": "continuous",
    "browser_location": "remote_machine",
    "browser_streaming": "browserless_screencast_websocket",
    "agent_location": "remote_machine",
    "code_server_model": "one_per_machine_shared",
    "api_transport": "rest_plus_websocket",
    "websocket_model": "dedicated_per_session",
    "credential_storage": "aes256_in_db",
    "master_key_source": "environment_variable",
    "auth_model": "single_user_mvp",
    "session_layout": "fixed_tabbed",
    "mobile_nav": "hamburger_drawer",
    "health_check": "periodic_heartbeat_30s",
    "connection_failure": "auto_retry_silent_exponential_backoff",
    "session_recovery": "auto_recreate_plus_notify",
    "machine_setup": "guided_assisted_installation",
    "repo_structure": "monorepo"
  },
  "data_model": {
    "users": {
      "fields": ["id (uuid)", "username (string, unique)", "password_hash (string, argon2)", "must_change_password (bool)", "created_at", "updated_at"]
    },
    "machines": {
      "fields": ["id (uuid)", "name (string)", "host (string)", "port (int)", "auth_type (enum: key/password)", "encrypted_credentials (blob)", "status (enum)", "capabilities (jsonb)", "last_heartbeat (timestamp)", "created_at", "updated_at"]
    },
    "projects": {
      "fields": ["id (uuid)", "machine_id (uuid, fk)", "name (string)", "directory_path (string)", "created_at", "updated_at"]
    },
    "sessions": {
      "fields": ["id (uuid)", "project_id (uuid, fk)", "name (string)", "status (enum)", "last_active (timestamp)", "created_at", "updated_at"]
    },
    "terminal_tabs": {
      "fields": ["id (uuid)", "session_id (uuid, fk)", "tmux_window_index (int)", "name (string)", "created_at"]
    },
    "app_sessions": {
      "fields": ["id (uuid)", "user_id (uuid, fk)", "session_token (string, unique)", "expires_at (timestamp)", "created_at"]
    }
  },
