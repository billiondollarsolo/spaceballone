    {"name": "SPACEBALLONE_MASTER_KEY", "description": "AES-256 key for credential encryption", "required": true},
    {"name": "DATABASE_URL", "description": "Database connection string", "default": "sqlite://spaceballone.db"},
    {"name": "PORT", "description": "API server port", "default": "8080"},
    {"name": "FRONTEND_URL", "description": "Frontend origin for CORS", "default": "http://localhost:3000"},
    {"name": "TLS_CERT_PATH", "description": "Path to TLS certificate", "required": false},
    {"name": "TLS_KEY_PATH", "description": "Path to TLS private key", "required": false},
